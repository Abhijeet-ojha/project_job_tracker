# Backend Environment Variables
# Copy this file to .env and fill in all values before running

PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/job_tracker?retryWrites=true&w=majority
JWT_SECRET=your_strong_random_secret_here
GEMINI_API_KEY=your_gemini_api_key_here
CLIENT_URL=http://localhost:5173,https://your-frontend-domain.vercel.app
